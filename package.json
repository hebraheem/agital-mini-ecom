{
  "name": "agita-e-com",
  "version": "1.0.0",
  "description": "Agital.soft GmbH E-commerce Platform",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install && npm install --prefix client && npm install --prefix server",
    "install:client": "npm install --prefix client",
    "install:server": "npm install --prefix server",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" --names \"SERVER,CLIENT\" --prefix-colors \"blue,green\"",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run start:dev --prefix server",
    "build": "npm run build:client && npm run build:server",
    "build:client": "npm run build --prefix client",
    "build:server": "npm run build --prefix server",
    "start": "concurrently \"npm run start:server\" \"npm run start:client\" --names \"SERVER,CLIENT\" --prefix-colors \"blue,green\"",
    "start:client": "npm run preview --prefix client",
    "start:server": "npm run start:prod --prefix server",
    "lint": "npm run lint --prefix client && npm run lint --prefix server",
    "lint:client": "npm run lint --prefix client",
    "lint:server": "npm run lint --prefix server",
    "test": "npm run test --prefix server",
    "test:server": "npm run test --prefix server",
    "seed": "npm run seed --prefix server",
    "clean": "rm -rf node_modules client/node_modules server/node_modules client/dist server/dist",
    "setup": "npm run install:all && npm run seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "author": "Agital.soft GmbH",
  "license": "UNLICENSED"
}

